#!/usr/bin/env sh
# Small launcher so commands read naturally as `./accessor run ...`.
DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
PYTHON="$DIR/.venv/bin/python"

if [ ! -x "$PYTHON" ]; then
  echo "Accessor dependency environment is missing: $DIR/.venv" >&2
  echo "Run: python3 -m venv .venv && .venv/bin/python -m pip install -r requirements.txt" >&2
  exit 1
fi

exec "$PYTHON" "$DIR/cli.py" "$@"
